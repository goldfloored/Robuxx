			<Item class="LocalScript" referent="RBXA5C47BCAD5584BFD820891B685D61750">
				<Properties>
					<ProtectedString name="Source"><![CDATA[-- LaserGun LocalScript: Phase 3 - Client Side
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local tool = script.Parent
local player = Players.LocalPlayer
local mouse = player:GetMouse()
local laserFired = ReplicatedStorage:WaitForChild("LaserFired")

local COOLDOWN = 0.3
local BEAM_LIFETIME = 0.1
local LASER_COLOR = BrickColor.new("Bright red")
local canShoot = true
local equipped = false

local function drawBeam(startPos: Vector3, endPos: Vector3)
	local beamPart = Instance.new("Part")
	beamPart.Anchored = true
	beamPart.CanCollide = false
	beamPart.CastShadow = false
	beamPart.BrickColor = LASER_COLOR
	beamPart.Material = Enum.Material.Neon
	beamPart.Name = "LaserBeam"
	local distance = (endPos - startPos).Magnitude
	beamPart.Size = Vector3.new(0.1, 0.1, distance)
	beamPart.CFrame = CFrame.lookAt(startPos, endPos) * CFrame.new(0, 0, -distance / 2)
	beamPart.Parent = workspace
	task.delay(BEAM_LIFETIME, function()
		if beamPart and beamPart.Parent then beamPart:Destroy() end
	end)
end

local function shoot()
	if not canShoot or not equipped then return end
	local character = player.Character
	if not character then return end
	canShoot = false
	local camera = workspace.CurrentCamera
	local unitRay = camera:ScreenPointToRay(mouse.X, mouse.Y)
	local rayOrigin = unitRay.Origin
	local rayDir = unitRay.Direction * 500
	local rayParams = RaycastParams.new()
	rayParams.FilterDescendantsInstances = {character}
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	local result = workspace:Raycast(rayOrigin, rayDir, rayParams)
	local hitPos = result and result.Position or (rayOrigin + rayDir)
	local hitEnemy: Model? = nil
	if result and result.Instance then
		local parent = result.Instance.Parent
		if parent and parent.Name == "Enemy" and parent:IsA("Model") then
			hitEnemy = parent
		end
	end
	local handle = tool:FindFirstChild("Handle")
	local muzzle = handle and handle:FindFirstChild("Muzzle")
	local startPos = muzzle and muzzle.WorldPosition or character:FindFirstChild("HumanoidRootPart").Position
	drawBeam(startPos, hitPos)
	if hitEnemy then laserFired:FireServer(hitEnemy, hitPos) end
	task.delay(COOLDOWN, function() canShoot = true end)
end

laserFired.OnClientEvent:Connect(function(shootingPlayer: Player, hitPosition: Vector3)
	if shootingPlayer == player then return end
	local char = shootingPlayer.Character
	if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if hrp then drawBeam(hrp.Position, hitPosition) end
end)

tool.Equipped:Connect(function()
	equipped = true
	mouse.Button1Down:Connect(shoot)
end)

tool.Unequipped:Connect(function()
	equipped = false
end)

print("[LaserGun] LocalScript loaded.")
]]></ProtectedString>
